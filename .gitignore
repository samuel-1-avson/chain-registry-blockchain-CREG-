.installed.cfg
*.egg
.mypy_cache/
.ruff_cache/

# =============================================================================
# IDE & EDITOR
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini
*.sublime-project
