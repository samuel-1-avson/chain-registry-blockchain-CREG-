# =============================================================================
*.bak
*.backup
*.old
*.orig
*.rej
*.patch
*.tmp
*.swn
*.pid
*.seed
core.*

# =============================================================================
# TESTNET GENERATED ARTIFACTS
# =============================================================================
**/testnet/artifacts/
**/config/*/deployment.json
config/local/
config/production/
!config/example/
!config/template/
scripts/*.key
scripts/*.json
!scripts/*.py
!scripts/*.ps1
!scripts/*.sh

# =============================================================================
# PLAYGROUND & DEMO PAYLOADS
# =============================================================================
playground/
**/playground/

# =============================================================================
# ALLOW THESE (Must come after ignores)
# =============================================================================
!.github/
!.dockerignore
!.gitmodules
!.env.example
!**/.env.*.example
# Repository-root documentation (Phase 1); **/docs/ above still ignores other docs trees
!/docs/
!/docs/**
!/docs/**/*.md
!chain-registry/migrations/README.md
