# =============================================================================
# Chain Registry Workspace — Root .gitignore
# SECURITY: Never commit private keys, seed phrases, or credentials
# POLICY: Only source code and scripts are tracked.
#         No docs, models, packages, libraries, or generated artifacts.
# =============================================================================

# =============================================================================
# DOCUMENTATION — ALL .md files ignored (allow README.md)
# =============================================================================
*.md
!README.md
!chain-registry/migrations/README.md
!chain-registry/contracts/README.md

# =============================================================================
# DOCS DIRECTORY
# =============================================================================
docs/
**/docs/

# =============================================================================
# ENVIRONMENT & SECRETS (CRITICAL — NEVER COMMIT)
# =============================================================================
.env
.env.*
!.env.example
*.env
secrets/
**/secrets/
*secret*
# SEC-301b: hot-key loader crate (source only — not credential files)
!chain-registry/crates/secrets/
!chain-registry/crates/secrets/**
!.gitignore

# =============================================================================
# KEYS & CREDENTIALS (CRITICAL)
# =============================================================================
*.key
**/*.key
*.pem
**/*.pem
*.p12
*.pfx
*.crt
*.cer
*.pub
*.priv
*password*
*credential*
*wallet*
*mnemonic*
*seed*
private*
privkey*
publisher.key
**/publisher.key
*.jks
*.keystore
*.asc

# =============================================================================
# VALIDATOR KEYS (CRITICAL)
# =============================================================================
validator-keys/
**/validator-keys/
validators/
**/validators/
generated-keys/
testnet-keys/

# =============================================================================
# KUBERNETES SECRETS
# =============================================================================
k8s/*secret*
**/k8s/*secret*

# =============================================================================
# RUST BUILD ARTIFACTS & BINARIES
# =============================================================================
target/
**/target/
**/target[0-9]*/
target-*/
*.pdb
*.exe
creg
creg-node
creg-cli

# =============================================================================
# SMART CONTRACT BUILD ARTIFACTS
# =============================================================================
out/
**/out/
cache/
**/cache/
broadcast/
**/broadcast/
foundry.lock
**/foundry.lock
deployments/
**/deployments/

# =============================================================================
# ZK CIRCUIT BUILD ARTIFACTS & KEYS
# =============================================================================
circuits/build/
circuits/keys/
**/circuits/build/
**/circuits/keys/
*.r1cs
*.zkey
*.ptau
*.sym
!circuits/*.circom
!**/circuits/*.circom

# =============================================================================
# ML MODELS & TRAINING DATA
# =============================================================================
models/
**/models/
secret-model/
**/secret-model/
*.pkl
*.onnx
*.pt
*.pth
*.h5
*.safetensors
datasets/
**/datasets/

