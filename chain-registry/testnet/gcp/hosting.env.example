# Copy to hosting.env (gitignored) and customize.
# Used by testnet/gcp/*.ps1 scripts.

GCP_PROJECT=gen-lang-client-0022105784
GCP_REGION=us-central1
GCP_ZONE=us-central1-a
GCP_VM_NAME=creg-testnet-vm
GCP_MACHINE_TYPE=e2-standard-4
GCP_BOOT_DISK_GB=100
GCP_STATIC_IP_NAME=creg-testnet-ip
GCP_TESTNET_TAG=creg-testnet

# Option A: internal Sepolia Geth (see docs/GCP-SEPOLIA-GETH-INTERNAL.md)
GCP_SEPOLIA_GETH_VM_NAME=creg-sepolia-geth-vm
GCP_SEPOLIA_GETH_TAG=creg-sepolia-geth
GCP_SEPOLIA_GETH_INTERNAL_IP_NAME=creg-sepolia-geth-internal-ip
GCP_SEPOLIA_GETH_MACHINE_TYPE=e2-standard-2
# 100GB fits default 250GB SSD regional quota with creg-testnet-vm (100GB boot).
GCP_SEPOLIA_GETH_DISK_GB=100

# Option A: dedicated validator fleet VM (see docs/GCP-VALIDATOR-FLEET.md)
GCP_VALIDATOR_VM_NAME=creg-validator-vm
GCP_VALIDATOR_TAG=creg-validators
GCP_VALIDATOR_INTERNAL_IP_NAME=creg-validator-internal-ip
GCP_VALIDATOR_MACHINE_TYPE=e2-standard-8
# New GCP projects often have CPUS_ALL_REGIONS=12; 2+4+8=14 needs quota increase or edge e2-standard-2 (2+2+8=12) or validator e2-standard-4 (fits 10 vCPU).
# 50GB fits default SSD_TOTAL_GB=250 with edge (100) + geth (100): 100+100+50=250.
GCP_VALIDATOR_DISK_GB=50

PARENT_DOMAIN=cregnet.dev
BASE_DOMAIN=testnet.cregnet.dev
ACME_EMAIL=samuelavson@gmail.com

GITHUB_REPO=samuel-1-avson/chain-registry-blockchain-CREG-
GITHUB_BRANCH=main

# Optional: Cloudflare API token (Zone.DNS Edit on cregnet.dev) for set-cloudflare-dns.ps1
# CF_API_TOKEN=

# Waitlist static site uses this VM (deploy-waitlist.ps1). Registration backend is a
# separate Firebase/GCP project (see docs/GCP-BUDGET-ARCHITECTURE.md).
GCP_WAITLIST_PROJECT=gen-lang-client-0098858574
# CREG_PUBLIC_WAITLIST_HOST=waitlist.cregnet.dev

# Phase 1 cost optimization (see docs/GCP_PHASE1_RUNBOOK.md)
GCP_COST_LABEL_ENV=public-alpha
GCP_COST_LABEL_OWNER=creg
GCP_COST_LABEL_COST_CENTER=testnet
GCP_BUDGET_TESTNET_USD=300
GCP_BUDGET_WAITLIST_USD=25
# GCP_BUDGET_ALERT_EMAIL=ops@example.com

# Alertmanager receivers (deploy-monitoring.ps1 generates alertmanager-gcp.yml)
# Default push alerts (no Slack): run setup-alert-receiver.ps1
# GCP_ALERT_NTFY_TOPIC=creg-testnet-alerts-123456
# GCP_ALERT_NTFY_SERVER=https://ntfy.sh
# GCP_ALERT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# GCP_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...
# GCP_ALERT_PAGERDUTY_ROUTING_KEY=
# GCP_ALERT_EMAIL_TO=ops@example.com
# GCP_ALERT_SMTP_HOST=smtp.gmail.com:587
# GCP_ALERT_SMTP_USER=ops@example.com
# GCP_ALERT_SMTP_PASSWORD=

GCP_STATIC_BUCKET=creg-testnet-static-gen-lang-client-0022105784

# Phase 2 â€” elastic public layer (see docs/GCP_PHASE2_RUNBOOK.md)
GCP_OBSERVER_MIG_NAME=creg-observer-pool
GCP_OBSERVER_MACHINE_TYPE=e2-medium
GCP_OBSERVER_DISK_GB=10
GCP_OBSERVER_DISK_TYPE=pd-standard
GCP_OBSERVER_TAG=creg-observers
GCP_OBSERVER_ILB_NAME=creg-observer-api-ilb
GCP_OBSERVER_ILB_IP_NAME=creg-observer-api-ilb-ip
# After provision-observer-pool.ps1 -Confirm, copy ILB IP into testnet/sepolia-3node.env:
# CREG_OBSERVER_POOL_LB_IP=10.x.x.x
# CREG_OBSERVER_API_UPSTREAM=10.x.x.x:28182

GCP_HUB_API_SERVICE=creg-hub-api
GCP_ARTIFACT_REPO=creg-testnet
# CREG_HUB_API_CLOUD_RUN_URL=https://creg-hub-api-....run.app

GCP_ARMOR_POLICY_NAME=creg-testnet-edge
# Cloud Armor requires non-zero quota in some GCP projects; if provision fails,
# keep FAUCET_POW_DISABLED=false on edge and document in HUB_API_REMEDIATION_STATUS.md.
GCP_EDGE_BACKEND_NAME=creg-edge-api-backend
GCP_API_LB_IP_NAME=creg-api-lb-ip
