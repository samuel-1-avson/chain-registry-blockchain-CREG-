# Copy to hosting.env (gitignored) and customize.
# Used by testnet/gcp/*.ps1 scripts.

GCP_PROJECT=gen-lang-client-0022105784
GCP_REGION=us-central1
GCP_ZONE=us-central1-a
GCP_VM_NAME=creg-testnet-vm
GCP_MACHINE_TYPE=e2-standard-4
GCP_BOOT_DISK_GB=100
GCP_STATIC_IP_NAME=creg-testnet-ip
GCP_TESTNET_TAG=creg-testnet

# Option A: internal Sepolia Geth (see docs/GCP-SEPOLIA-GETH-INTERNAL.md)
GCP_SEPOLIA_GETH_VM_NAME=creg-sepolia-geth-vm
GCP_SEPOLIA_GETH_TAG=creg-sepolia-geth
GCP_SEPOLIA_GETH_INTERNAL_IP_NAME=creg-sepolia-geth-internal-ip
GCP_SEPOLIA_GETH_MACHINE_TYPE=e2-standard-2
# 100GB fits default 250GB SSD regional quota with creg-testnet-vm (100GB boot).
GCP_SEPOLIA_GETH_DISK_GB=100

# Option A: dedicated validator fleet VM (see docs/GCP-VALIDATOR-FLEET.md)
GCP_VALIDATOR_VM_NAME=creg-validator-vm
GCP_VALIDATOR_TAG=creg-validators
GCP_VALIDATOR_INTERNAL_IP_NAME=creg-validator-internal-ip
GCP_VALIDATOR_MACHINE_TYPE=e2-standard-8
# New GCP projects often have CPUS_ALL_REGIONS=12; 2+4+8=14 needs quota increase or edge e2-standard-2 (2+2+8=12) or validator e2-standard-4 (fits 10 vCPU).
# 50GB fits default SSD_TOTAL_GB=250 with edge (100) + geth (100): 100+100+50=250.
GCP_VALIDATOR_DISK_GB=50

PARENT_DOMAIN=cregnet.dev
BASE_DOMAIN=testnet.cregnet.dev
ACME_EMAIL=samuelavson@gmail.com

GITHUB_REPO=samuel-1-avson/chain-registry-blockchain-CREG-
GITHUB_BRANCH=main

# Optional: Cloudflare API token (Zone.DNS Edit on cregnet.dev) for set-cloudflare-dns.ps1
# CF_API_TOKEN=

# Waitlist static site uses this VM (deploy-waitlist.ps1). Registration backend is a
# separate Firebase/GCP project: gen-lang-client-0098858574 (see docs/GCP-BUDGET-ARCHITECTURE.md).
# CREG_PUBLIC_WAITLIST_HOST=waitlist.cregnet.dev
