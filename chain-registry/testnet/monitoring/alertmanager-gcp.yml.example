# Example Alertmanager config for the GCP testnet monitoring stack.
# deploy-monitoring.ps1 generates alertmanager-gcp.yml (gitignored) from hosting.env:
#   GCP_ALERT_SLACK_WEBHOOK_URL   — Slack incoming webhook (recommended)
#   GCP_ALERT_PAGERDUTY_ROUTING_KEY — PagerDuty Events API v2 routing key (optional)

global:
  resolve_timeout: 5m

route:
  group_by: [alertname, instance]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: default

  routes:
    - match:
        severity: critical
      receiver: critical
      repeat_interval: 30m
    - match:
        severity: warning
      receiver: warning

receivers:
  - name: default
    webhook_configs:
      - url: "https://hooks.slack.com/services/REPLACE_ME"
        send_resolved: true

  - name: critical
    webhook_configs:
      - url: "https://hooks.slack.com/services/REPLACE_ME"
        send_resolved: true
    pagerduty_configs:
      - routing_key: "REPLACE_PAGERDUTY_ROUTING_KEY"
        send_resolved: true

  - name: warning
    webhook_configs:
      - url: "https://hooks.slack.com/services/REPLACE_ME"
        send_resolved: true

inhibit_rules:
  - source_match:
      alertname: CregNodeDown
    target_match:
      alertname: CregBlockProductionStalled
    equal: [instance]
