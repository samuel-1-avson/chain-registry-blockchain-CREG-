# Chain Registry — 3-Node Sepolia Docker Fleet
#
# Quick start (recommended):
#   .\testnet\init-sepolia-3node-env.ps1
#   .\testnet\start-3node-test.ps1
#
# Manual copy:
#   Copy-Item testnet\sepolia-3node.env.example testnet\sepolia-3node.env
#
# start-3node-test.ps1 also merges testnet/.env.sepolia when sepolia-3node.env is missing.

# ── Sepolia RPC (required) ──
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
CREG_ETH_RPC=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Host port for 3-node IPFS API (containers use http://ipfs:5001 internally)
CREG_3NODE_IPFS_HOST_PORT=15001
CREG_3NODE_SPEC_HOST_PORT=18888
# Host ports for node APIs/P2P (avoid clashes with creg-node, minio, faucet, etc.)
CREG_3NODE_NODE1_API_PORT=28180
CREG_3NODE_NODE1_P2P_PORT=29100
CREG_3NODE_NODE2_API_PORT=28181
CREG_3NODE_NODE2_P2P_PORT=29101
CREG_3NODE_NODE3_API_PORT=28182
CREG_3NODE_NODE3_P2P_PORT=29102
CREG_3NODE_FAUCET_PORT=8082
CREG_3NODE_EXPLORER_PORT=3007

# Security / bridge (optional — enables L1 anchoring when set on validator-1)
# CREG_BRIDGE_KEY=0x...
# CREG_OPERATOR_API_KEY=docker-dev-operator-key

# Windows soak without nsjail: CREG_DEV_SANDBOX=true

# Faucet (optional — start with .\testnet\start-3node-public.ps1 -WithFaucet)
# FAUCET_PRIVATE_KEY=0x...
# FAUCET_ADDRESS=0x...

# ── Sepolia contracts (optional — compose defaults match chain-spec.sepolia.json) ──
# CREG_REGISTRY_ADDR=0x3aCfF05d00AC199412a94326eD8aA874aaA3596c
# CREG_STAKING_ADDR=0xf28C63C4Aafd27025E535Ab9ab7B4daC18C96Bc2
# CREG_GOVERNANCE_ADDR=0x9a14F359E2bdBb43F1526743C4A91955F29Ba59A
# CREG_TOKEN_ADDR=0x97c21d46B3eac604e92E907D54aA92eEc0Af550b

# ── Validator Ed25519 seeds (32-byte hex) ──
# Use init-sepolia-3node-env.ps1 for working defaults (KEY_1 = chain-spec core-1).
CREG_VALIDATOR_KEY_1=0xREPLACE_WITH_VALIDATOR_1_ED25519_SEED
CREG_VALIDATOR_KEY_2=0xREPLACE_WITH_VALIDATOR_2_ED25519_SEED

# For on-chain validator-2 registration (never commit):
# VALIDATOR_2_ETH_PRIVATE_KEY=0x...   # Sepolia wallet with >= 100 tCREG for applyToBeValidator
