# =============================================================================
# Chain Registry Node - Git Ignore
# SECURITY: Never commit private keys, seed phrases, or API credentials
# =============================================================================

# =============================================================================
# DOCUMENTATION (Only README.md is kept)
# =============================================================================
*.md
!README.md

# =============================================================================
# ENVIRONMENT & SECRETS (CRITICAL - NEVER COMMIT)
# =============================================================================
.env
.env.*
!.env.example
.env.local
.env.production
.env.staging
secrets/
*secret*
*password*
*credential*
*.key
*.pem
*.p12
*.pfx
private*
privkey*

# =============================================================================
# VALIDATOR KEYS (CRITICAL - NEVER COMMIT)
# =============================================================================
validator*
!validator*/README*
!validator*/.gitkeep
publisher.key
testnet-keys/
generated-keys/
*.pub
*.priv

# =============================================================================
# SMART CONTRACT BUILD ARTIFACTS
# =============================================================================
/target/
/target[0-9]*/
**/*.target/
Cargo.lock
*.pdb
*.exe
creg
creg-node
creg-cli

# Solidity build artifacts
contracts/out/
contracts/cache/
contracts/broadcast/
contracts/foundry.lock
contracts/remappings.txt
deployments/local/
deployments/anvil/

# =============================================================================
# ZK CIRCUIT ARTIFACTS (Large files, can be regenerated)
# =============================================================================
circuits/build/
circuits/keys/
circuits/*.r1cs
circuits/*.wasm
circuits/*.sym
circuits/*.zkey
circuits/*.ptau

# =============================================================================
# ML MODELS (Large files)
# =============================================================================
ml/models/
ml/training/chain-registry/
ml/training/*.pkl
ml/training/*.onnx
ml/training/*.pt
ml/training/*.pth

# =============================================================================
# DATA & STORAGE
# =============================================================================
/data/
/node*-data/
/validator*-data/
/ipfs-data/
/postgres-data/
/dev-data/
/tmp/
/temp/
*.db
*.sqlite
*.sqlite3
anvil_state.json

# =============================================================================
# LOGS
# =============================================================================
*.log
logs/
node_err.log
publish_log.txt
build_log.txt
api-test.log
check.log
cli-check.log
node-check*.log

# =============================================================================
# PACKAGE ARTIFACTS
# =============================================================================
*.tgz
*.tar.gz
*.zip
demo-v2/
malicious-pkg/
good-pkg-v1/
good-pkg-v2/
evil-pkg-v1/
package/
packages/

# =============================================================================
# NODE.JS / NPM
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# =============================================================================
# PYTHON
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =============================================================================
# IDE & EDITOR
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# COVERAGE & TESTING
# =============================================================================
coverage/
*.coverage
htmlcov/
.tox/
.nox/
.pytest_cache/

# =============================================================================
# PROJECT SPECIFIC
# =============================================================================
.gemini/
.claude/
.cursor/

# Config files with real values
config/*/deployment.json
config/local/
config/production/

# Generated testnet files
scripts/*.key
scripts/*.json

# =============================================================================
# ALLOW THESE
# =============================================================================
!README.md
!CONTRIBUTING.md
!LICENSE
!.gitignore
