# =============================================================================
# Chain Registry Node — Inner Project .gitignore
# SECURITY: Never commit private keys, seed phrases, or credentials
# POLICY: Only source code and scripts are tracked.
#         No docs, models, packages, libraries, or generated artifacts.
# =============================================================================

# =============================================================================
# DOCUMENTATION — ALL .md files ignored
# =============================================================================
*.md

# =============================================================================
# DOCS DIRECTORY
# =============================================================================
docs/

# =============================================================================
# ENVIRONMENT & SECRETS (CRITICAL — NEVER COMMIT)
# =============================================================================
.env
.env.*
.env.backup.*
*.env
secrets/
*secret*
!.gitignore

# =============================================================================
# KEYS & CREDENTIALS (CRITICAL)
# =============================================================================
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.pub
*.priv
*password*
*credential*
*wallet*
*mnemonic*
*seed*
private*
privkey*
publisher.key

# =============================================================================
# VALIDATOR KEYS (CRITICAL)
# =============================================================================
validator-keys/
validators/

# =============================================================================
# KUBERNETES SECRETS
# =============================================================================
k8s/*secret*

# =============================================================================
# RUST BUILD ARTIFACTS & BINARIES
# =============================================================================
/target/
/target[0-9]*/
/target-*/
Cargo.lock
*.pdb
*.exe
creg
creg-node
creg-cli

# =============================================================================
# SMART CONTRACT BUILD / SOLIDITY ARTIFACTS
# =============================================================================
contracts/out/
contracts/cache/
contracts/broadcast/
contracts/foundry.lock
contracts/deployments/
foundry.lock
remappings.txt

# =============================================================================
# ZK CIRCUIT BUILD ARTIFACTS & KEYS
# =============================================================================
circuits/build/
circuits/keys/
*.r1cs
*.zkey
*.ptau
*.sym
!circuits/*.circom

# =============================================================================
# ML MODELS & TRAINING DATA
# =============================================================================
models/
ml/training/
secret-model/
*.pkl
*.onnx
*.pt
*.pth
*.bin
*.h5
*.safetensors

# =============================================================================
# DATA & STORAGE
# =============================================================================
/data/
/node*-data/
/validator*-data/
/ipfs-data/
/postgres-data/
/dev-data/
/tmp/
/temp/
*.db
*.sqlite
*.sqlite3
anvil_state.json

# =============================================================================
# LOGS
# =============================================================================
*.log
*.log.*
logs/

# =============================================================================
# PACKAGE ARTIFACTS & TARBALLS
# =============================================================================
*.tgz
*.tar.gz
*.zip
*.tar
demo-v2/
malicious-pkg/
good-pkg-v1/
good-pkg-v2/
evil-pkg-v1/
package/
packages/
dist/
stress-report-out/

# =============================================================================
# NODE.JS / NPM (libraries)
# =============================================================================
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# =============================================================================
# PYTHON (libraries)
# =============================================================================
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =============================================================================
# IDE & EDITOR
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# =============================================================================
# AI TOOL DIRECTORIES
# =============================================================================
.blackboxcli/
.claude/
.cursor/
.gemini/
.ai/
.playwright-mcp/

# =============================================================================
# COVERAGE & TESTING
# =============================================================================
coverage/
**/coverage/
*.coverage
htmlcov/
.tox/
.nox/
.pytest_cache/

# =============================================================================
# DOCKER
# =============================================================================
docker-compose.override.yml

# =============================================================================
# MISCELLANEOUS
# =============================================================================
*.bak
*.backup
*.old
*.orig
*.rej
*.patch

# =============================================================================
# TESTNET GENERATED ARTIFACTS
# =============================================================================
testnet/artifacts/
config/*/deployment.json
config/local/
config/production/
scripts/*.key
scripts/*.json
!scripts/*.py
!scripts/*.ps1
!scripts/*.sh

# =============================================================================
# PLAYGROUND (demo test payloads)
# =============================================================================
playground/
