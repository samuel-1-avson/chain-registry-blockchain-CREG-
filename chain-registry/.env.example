# Chain Registry (CREG) Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to git - it contains sensitive keys!

# =============================================================================
# VALIDATOR KEYS (CRITICAL - Generate using: cargo run --bin creg -- keygen)
# =============================================================================
# These are Ed25519 private keys for validators
# For testnet testing, you can run multiple validators on one PC
# For production: ONE VALIDATOR PER PC ONLY

# Validator 1 (Primary/Seed Node)
NODE1_VALIDATOR_KEY=your_validator_1_private_key_here

# Validator 2
NODE2_VALIDATOR_KEY=your_validator_2_private_key_here

# Validator 3
NODE3_VALIDATOR_KEY=your_validator_3_private_key_here

# Validator 4 (Optional - for 4+ validator testnet)
NODE4_VALIDATOR_KEY=your_validator_4_private_key_here

# Validator 5 (Optional)
NODE5_VALIDATOR_KEY=your_validator_5_private_key_here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_PASSWORD=secure_postgres_password_change_me

# =============================================================================
# ETHEREUM RPC (for testnet, uses local Anvil)
# =============================================================================
# Local Anvil RPC URL (default)
ETH_RPC_URL=http://localhost:8545

# For external testnets (uncomment if needed)
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
# MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# Testnet deployment account (Anvil account #0 by default)
DEPLOYER_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Bridge account used by the node for Ethereum settlement.
# HOT KEY — never commit real mainnet keys; rotate if exposed (see docs/SECURITY_OPS_RUNBOOK.md).
# Default below is Anvil account #2 for local dev only.
CREG_BRIDGE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# Set true on testnet/Sepolia nodes to allow dev keys without hot-key startup warnings.
CREG_TESTNET=false

# Explorer dev-mode toggle. Set to false for production-style builds to hide raw private key wallet input.
VITE_DEV_MODE=true

# =============================================================================
# FAUCET CONFIGURATION (Testnet Only)
# =============================================================================
# Faucet private key (Anvil account #1 by default). HOT KEY — testnet only unless CREG_TESTNET=true.
FAUCET_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# =============================================================================
# RELAYER (sponsored stake)
# =============================================================================
# HOT KEY — same rules as FAUCET_PRIVATE_KEY / CREG_BRIDGE_KEY.
RELAYER_PRIVATE_KEY=0x2a871d0798f97d79848a013d4936a73bf4cc922c325d5dc0003f279c7aa26f8f
RELAYER_RPC_URL=http://localhost:8545
RELAYER_PORT=8083

# Faucet address (must match the private key above)
FAUCET_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8

# Faucet RPC / port
FAUCET_RPC_URL=http://localhost:8545
FAUCET_PORT=8082

# Token contract used by the faucet after deployment
FAUCET_TOKEN_CONTRACT=

# Initial faucet reserve to transfer in after a fresh deploy (default: 10000 tCREG)
FAUCET_INITIAL_BALANCE=10000000000000000000000

# Faucet drip amount (in wei, default: 1000 tCREG)
FAUCET_DRIP_AMOUNT=1000000000000000000000

# Faucet cooldown (seconds between requests)
FAUCET_COOLDOWN_SECS=60

# =============================================================================
# AI/ML API KEYS (Optional - for enhanced ML validation)
# =============================================================================
# OpenRouter API key for LLM analysis
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Anthropic API key for Claude analysis
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# IPFS CONFIGURATION
# =============================================================================
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8081

# =============================================================================
# NODE CONFIGURATION
# =============================================================================
# Node ID (must be unique per validator)
CREG_NODE_ID=node-1

# P2P listen address
CREG_P2P_LISTEN=/ip4/0.0.0.0/tcp/9000

# P2P bootstrap seeds (comma-separated list of multiaddrs)
# Example: /ip4/192.168.1.100/tcp/9000/p2p/12D3KooW...
CREG_P2P_SEEDS=

# API port
CREG_API_PORT=8080

# gRPC port
CREG_GRPC_PORT=50051

# Data directory
CREG_DATA_DIR=./data

# PBFT quorum override for small local clusters only. Leave unset/false outside
# local bootstrap; enabling it allows a 3-validator cluster to make progress
# with a 2-of-3 majority instead of strict 3-of-3 quorum.
CREG_PBFT_ALLOW_SMALL_CLUSTER_QUORUM=false

# =============================================================================
# TESTNET CONTRACT ADDRESSES (Auto-populated after deployment)
# =============================================================================
# These are populated by testnet/deploy-testnet.sh
TESTNET_TOKEN_ADDR=
TESTNET_STAKING_ADDR=
TESTNET_REGISTRY_ADDR=
TESTNET_GOVERNANCE_ADDR=
TESTNET_REPUTATION_ADDR=
TESTNET_VRF_ADDR=
TESTNET_APPEAL_ADDR=

# =============================================================================
# LOGGING
# =============================================================================
RUST_LOG=info,chain_registry_node=debug
