# Chain Registry Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# VALIDATOR KEYS (Generate with: creg keygen validator)
# =============================================================================
NODE1_VALIDATOR_KEY=0x...
NODE2_VALIDATOR_KEY=0x...
NODE3_VALIDATOR_KEY=0x...

# =============================================================================
# DEPLOYMENT KEYS (Anvil defaults)
# =============================================================================
# Default account 0 key used for local deployment
DEPLOYER_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# =============================================================================
# API KEYS (Optional - for enhanced AI/ML features)
# =============================================================================
# OpenRouter API key for AI-powered validation
OPENROUTER_API_KEY=sk-or-v1-...

# Anthropic API key for Claude integration
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# PHASE 1: ZK VALIDATION CONFIGURATION
# =============================================================================
# Enable ZK proof validation
CREG_ZK_ENABLED=true

# Path to ZK circuits (mounted in container)
CREG_ZK_CIRCUITS_PATH=./circuits

# ZK Verifier contract address (Anvil default)
CREG_ZK_VERIFIER_ADDR=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512

# =============================================================================
# PHASE 1: ML VALIDATION CONFIGURATION
# =============================================================================
# Enable ML threat detection
CREG_ML_ENABLED=true

# Path to ML models (if using ONNX models)
CREG_ML_MODEL_PATH=./models

# =============================================================================
# PHASE 1: WASM SANDBOX CONFIGURATION
# =============================================================================
# Enable WASM sandboxing
CREG_WASM_ENABLED=true

# Path to WASM validators
CREG_WASM_VALIDATORS_PATH=./validators

# Memory limit for WASM sandbox (bytes)
CREG_WASM_MEMORY_LIMIT=268435456

# Timeout for WASM execution (seconds)
CREG_WASM_TIMEOUT=30

# =============================================================================
# PHASE 2: CORE CONTRACT ADDRESSES (Anvil defaults)
# =============================================================================
# Registry contract
CREG_REGISTRY_ADDR=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Staking contract
CREG_STAKING_ADDR=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512

# Reputation contract
CREG_REPUTATION_ADDR=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0

# VRF contract
CREG_VRF_ADDR=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9

# Governance contract (original)
CREG_GOVERNANCE_ADDR=0xDc64a140Aa3E981100a9becA4E685f962f0cF6C9

# =============================================================================
# PHASE 2: ADVANCED CONTRACT ADDRESSES
# =============================================================================
# ZK Verifier contract
CREG_ZK_VERIFIER_ADDR=0x5FC8d32690cc91D4c39d9d3abcBD16989F875707

# Private Registry contract
CREG_PRIVATE_REGISTRY_ADDR=0x0165878A594ca255338adfa4d48449f69242Eb8F

# Cross-Chain Registry contract
CREG_CROSS_CHAIN_ADDR=0xa513E6E4b8f2a923D98304ec87F64353C4D5C853

# =============================================================================
# PHASE 3: ECOSYSTEM CONTRACT ADDRESSES
# =============================================================================
# CREG Token contract
CREG_CREG_TOKEN_ADDR=0x2279B7A0a67DB372996a5FaB50D91eAA73d2eBe6

# Governance V2 contract
CREG_GOVERNANCE_V2_ADDR=0x8A791620dd6260079BF849Dc5567aDC3F2FdC318

# Package Insurance contract
CREG_INSURANCE_ADDR=0x610178dA211FEF7D417bC0e6FeD39F05609AD788

# =============================================================================
# PHASE 3: INSURANCE CONFIGURATION
# =============================================================================
# Enable insurance features
CREG_INSURANCE_ENABLED=true

# Base premium rate (basis points, 100 = 1%)
CREG_BASE_PREMIUM_RATE=100

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================
# Ethereum RPC URL
CREG_ETH_RPC=http://localhost:8545

# IPFS URL
CREG_IPFS_URL=http://localhost:5001

# Node listen address
CREG_LISTEN=0.0.0.0:8080

# P2P listen address
CREG_P2P_LISTEN=/ip4/0.0.0.0/tcp/4001

# Block interval (seconds)
CREG_BLOCK_INTERVAL=5

# =============================================================================
# LOGGING
# =============================================================================
# Rust log level
RUST_LOG=info,chain_registry_node=debug

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Postgres connection details
POSTGRES_USER=creg
POSTGRES_PASSWORD=creg
POSTGRES_DB=chain_registry
CREG_PG_URL=postgres://creg:creg@localhost:5432/chain_registry

# Specific module logging
# RUST_LOG=zk_validator=debug,ml_validator=debug,wasm_sandbox=debug
