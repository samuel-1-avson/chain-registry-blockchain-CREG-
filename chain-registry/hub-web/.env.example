# Optional: WalletConnect for mobile / QR connect (injected wallets work without this).
# Create a free project at https://cloud.walletconnect.com
# Also install the optional package: npm install @walletconnect/ethereum-provider
VITE_WALLETCONNECT_PROJECT_ID=

# External tool URLs (defaults match cregnet.dev testnet)
VITE_EXPLORER_URL=https://explorer.testnet.cregnet.dev
VITE_FAUCET_URL=https://faucet.testnet.cregnet.dev
# Optional overrides (hub serves /docs and /api by default)
# VITE_DOCS_URL=
# VITE_API_DOCS_URL=https://api.testnet.cregnet.dev/api-docs/
VITE_API_URL=https://api.testnet.cregnet.dev
